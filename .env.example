# =============================================================================
# .env.local plantilla — copia este fichero a `.env.local` y rellena tus valores.
# `.env.local` esta en .gitignore, NUNCA se publica.
# =============================================================================


# -----------------------------------------------------------------------------
# 1) SPOTIFY (Vite, va al bundle del navegador)
# -----------------------------------------------------------------------------
# 1. Crea una app en https://developer.spotify.com/dashboard
# 2. Anade como Redirect URI en tu app:
#       http://127.0.0.1:5173/callback                          (desarrollo)
#       https://cadencia.movimientofuncional.app/callback       (produccion web)
#
#    Importante: usa 127.0.0.1 (no "localhost"). Spotify dejo de aceptar
#    "localhost" en HTTP a finales de 2024; solo permite la IP loopback.
# 3. Copia el Client ID (no necesitas Client Secret con PKCE).
VITE_SPOTIFY_CLIENT_ID=


# -----------------------------------------------------------------------------
# 2) HOSTINGER FTP (deploy a cadencia.movimientofuncional.app)
# -----------------------------------------------------------------------------
# Estas variables NO empiezan por VITE_ -> Vite NO las expone al bundle.
# Solo las lee el script scripts/deploy.sh.
#
# IMPORTANTE: el FTP user de Hostinger ya empieza en public_html del subdominio.
# Por eso FTP_REMOTE_DIR=/ es la raiz publica de la web. NO usar rutas
# absolutas tipo /home/uXXX/domains/... porque tu user NO tiene permisos
# para navegar fuera de su public_html.
FTP_HOST=ftp.cadencia.movimientofuncional.app
FTP_USER=u259555594.cadencia
FTP_PASS=
FTP_REMOTE_DIR=/
