# Fallback a index.html para SPA routing
# La app maneja /callback (Spotify OAuth) en JavaScript. Sin este fallback,
# Apache devolveria 404 al refrescar en /callback o entrar directamente.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Si la URL es un fichero o directorio real, servirlo directamente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Cualquier otra cosa: servir index.html (la SPA decide que mostrar)
  RewriteRule . /index.html [L]
</IfModule>

# Compresion gzip / brotli para assets de texto (Hostinger soporta ambos)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache largo para assets con hash en el nombre (Vite genera assets/index-XXXXX.js)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|svg|png|jpg|jpeg|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html y manifest no se cachean (hay que recargar para nuevas versiones)
  <FilesMatch "\.(html|webmanifest)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Forzar HTTPS (Hostinger te activa el SSL gratuito automaticamente)
<IfModule mod_rewrite.c>
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# === Headers de seguridad ===
# Una app cliente-only que maneja OAuth (Spotify + Google Drive) y procesa
# inputs no confiables (GPX, CSV, .zwo) necesita defensa en profundidad
# frente a XSS via dependencia comprometida, clickjacking, leak de Referer
# y downgrade HTTP. Verificar con securityheaders.com tras desplegar.
<IfModule mod_headers.c>
  # Content-Security-Policy:
  #   - default-src 'self': solo recursos del propio dominio por defecto.
  #   - script-src: GIS de Google (OAuth Drive) + IFrame API de Spotify (previews).
  #   - connect-src: endpoints de Spotify (auth + API), Google (OAuth + Drive).
  #   - frame-src: GIS popup (accounts.google.com) + embed de preview Spotify (open.spotify.com).
  #   - img-src: artwork de Spotify (i.scdn.co) ademas de self/data.
  #   - style-src 'unsafe-inline': obligado por Tailwind y por el JSON-LD inline.
  #   - font-src: Google Fonts (Righteous + ABeeZee declaradas en index.html).
  #   - frame-ancestors 'none': impide que cadencia.movimientofuncional.app sea
  #     embebida en un iframe hostil (anti-clickjacking).
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://accounts.google.com/gsi/client https://open.spotify.com; connect-src 'self' https://accounts.spotify.com https://api.spotify.com https://accounts.google.com https://www.googleapis.com https://oauth2.googleapis.com; frame-src https://accounts.google.com https://open.spotify.com; img-src 'self' data: https://i.scdn.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; manifest-src 'self'; base-uri 'self'; form-action 'self' https://accounts.spotify.com; frame-ancestors 'none'"

  # HSTS: 1 anyo + subdominios + preload-ready. Solo aplica en HTTPS.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Anti-MIME-sniffing.
  Header always set X-Content-Type-Options "nosniff"

  # Anti-clickjacking redundante con frame-ancestors (compatibilidad navegadores antiguos).
  Header always set X-Frame-Options "DENY"

  # No filtrar URLs internas en peticiones cross-origin.
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Bloquear APIs sensibles que la app no usa (geo, mic, cam, pago, USB).
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
</IfModule>
