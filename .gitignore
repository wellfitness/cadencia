# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
dist-ssr/
*.local

# Tests / coverage
coverage/
playwright-report/
test-results/
.vitest-cache/

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Env
.env
.env.local
.env.*.local

# Claude / Agent local config (per-user, not project-specific)
.claude/
.agent/
.claudehooks/

# TS incremental build cache
tsconfig.tsbuildinfo

# GPX files (rutas personales que no deben caer al repo publico)
*.gpx

# Design system local (no se publica al repo)
design-system/

# Deploy script local (especifico del setup de Hostinger del mantenedor;
# cada colaborador tiene su propio entorno de despliegue)
scripts/deploy.sh

# Fuentes locales para scripts de generacion de assets
# (se descargan al ejecutar generate-assets.py por primera vez)
scripts/fonts/

# Backups locales (logo original antes de optimizar, etc.)
scripts/.backup/

# Material local del mantenedor en la raiz: notas, exports puntuales de
# Spotify, PDFs de curso, etc. Se ignoran por nombre exacto a proposito
# para no esconder con un glob *.pdf / *.csv archivos que algun dia si
# deban entrar al repo.
/CICLO INDOOR Y PROGRESIONES - CICLO INDOOR.pdf
/Julio_3.csv
CICLO INDOOR Y PROGRESIONES.xlsx

# Originales de assets grandes en raiz (5-7 MB cada PNG). El asset que
# sirve la app son los .webp optimizados de public/. Los originales se
# regeneran/optimizan con scripts/generate-assets.py.
/hero_cadencia.png
/hero_cadencia_movil.png
